# ============================================================================
# Second Brain — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================================

# ---- Firebase (client SDK) — safe to expose, these are public identifiers ----
# Firebase console -> Project settings -> General -> Your apps -> SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Firebase Admin (server) — SECRET. Service account from Firebase console ----
# Project settings -> Service accounts -> Generate new private key.
# Paste the values from that JSON here. The private key must keep its \n escapes,
# so wrap the whole value in double quotes exactly as shown.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- Claude (Anthropic) — SECRET. The agent + RAG generation model ----
ANTHROPIC_API_KEY=
# Generation model for the agent + RAG answers. Default: claude-haiku-4-5 (cheapest).
# Swap to claude-opus-4-8 or claude-sonnet-5 for higher quality at higher cost.
CLAUDE_MODEL=claude-haiku-4-5

# ---- Voyage AI — SECRET. Document + query embeddings + reranking ----
# https://dash.voyageai.com/  (embed: voyage-3.5 1024-dim; rerank: rerank-2.5)
VOYAGE_API_KEY=
# Cross-encoder reranker used by the agentic retrieval loop (see docs/AGENTIC_RAG.md).
VOYAGE_RERANK_MODEL=rerank-2.5

# ---- Pinecone — SECRET. Vector store for the RAG knowledge base ----
# Create a NEW index for Voyage embeddings: dimension 1024, metric cosine.
PINECONE_API_KEY=
PINECONE_INDEX_NAME=second-brain

# ---- LangSmith — optional. Traces every model call in the agent + retrieval ----
# https://smith.langchain.com/   Leave LANGSMITH_TRACING=false to disable.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=second-brain-rag

# ---- Google Calendar sync — SECRET (OAuth 2.0 Web client) ----
# Google Cloud console -> APIs & Services -> Credentials -> Create OAuth client
# (Web). Enable the Google Calendar API. Add the redirect URI below. See
# docs/CALENDAR.md.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/calendar/callback
# Base URL used to build the OAuth return redirect (usually your app origin).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public HTTPS endpoint Google pushes calendar changes to (live reverse sync).
# Leave blank for one-way + manual "Sync now". For live sync locally, run a
# tunnel (cloudflared/ngrok) and set: https://<tunnel>/api/calendar/webhook
CALENDAR_WEBHOOK_URL=
